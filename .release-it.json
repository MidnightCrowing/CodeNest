{
  "npm": {
    "allowSameVersion": true,
    "publish": false
  },
  "github": {
    "release": true
  },
  "git": {
    "commitArgs": [
      "--no-verify"
    ],
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}"
  },
  "hooks": {
    "before:init": [
      "pnpm run check"
    ],
    "after:bump": [
      "pnpm run version:sync"
    ]
  }
}
