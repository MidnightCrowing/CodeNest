{
  "plugins": {
    "release-it-pnpm": {
      "publishCommand": "echo 'skipping publish'"
    }
  },
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}"
  },
  "hooks": {
    "before:init": [
      "pnpm update jetv-ui",
      "pnpm run lint",
      "git status --porcelain",
      "git diff pnpm-lock.yaml",
      "pnpm run typecheck"
    ],
    "after:bump": [
      "pnpm run build"
    ],
    "after:release": [
      "gh release upload v${version} build/*Setup*.exe build/*.dmg build/*.AppImage"
    ]
  }
}
