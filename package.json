{
  "name": "codenest",
  "type": "module",
  "version": "0.0.6",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "description": "Cross-platform local project manager",
  "author": "MidnightCrowing",
  "license": "MIT",
  "homepage": "https://github.com/MidnightCrowing/CodeNest",
  "repository": {
    "type": "git",
    "url": "https://github.com/MidnightCrowing/CodeNest.git"
  },
  "bugs": "https://github.com/MidnightCrowing/CodeNest/issues",
  "keywords": [
    "codenest",
    "cross-platform",
    "desktop-application",
    "project-management",
    "developer-tools"
  ],
  "release": "https://github.com/MidnightCrowing/CodeNest/releases",
  "readme": "https://github.com/MidnightCrowing/CodeNest/blob/main/README.md",
  "scripts": {
    "dev": "tauri dev",
    "dev:vue": "vite",
    "build": "tauri build",
    "build:vue": "vue-tsc --build && vite build",
    "icon:build": "node scripts/build-icons.js",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest run",
    "typecheck": "vue-tsc",
    "knip": "knip"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@vueuse/core": "^14.3.0",
    "fuse.js": "^7.4.2",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.9",
    "vue": "^3.5.35",
    "vue-i18n": "^11.4.5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.0.0",
    "@iconify-json/lucide": "^1.2.111",
    "@iconify/tools": "^5.0.12",
    "@intlify/unplugin-vue-i18n": "^11.2.3",
    "@tauri-apps/cli": "^2.11.2",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^10.4.1",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "jsdom": "^29.1.1",
    "knip": "^6.16.0",
    "lint-staged": "^17.0.7",
    "release-it": "^20.2.0",
    "sass": "^1.100.0",
    "simple-git-hooks": "^2.13.1",
    "terser": "^5.48.0",
    "typescript": "~6.0.3",
    "unocss": "^66.7.0",
    "unplugin-auto-import": "^21.0.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
